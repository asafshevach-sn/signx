# SignNow API
SIGNNOW_API_BASE_URL=https://api.signnow.com
SIGNNOW_CLIENT_ID=your_client_id
SIGNNOW_CLIENT_SECRET=your_client_secret
SIGNNOW_USERNAME=your_signnow_email
SIGNNOW_PASSWORD=your_signnow_password

# Anthropic (Claude AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google OAuth (client ID only — safe to expose in browser)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Frontend URL (for CORS) — set to your Vercel domain in production
FRONTEND_URL=https://your-app.vercel.app
